---
const { before, after } = Astro.props;
---
<div class="ba-grid">
  <div class="ba-box ba-before">
    <span class="ba-label">BEFORE</span>
    <p>{before}</p>
  </div>
  <div class="ba-arrow">→</div>
  <div class="ba-box ba-after">
    <span class="ba-label">AFTER</span>
    <p>{after}</p>
  </div>
</div>

<style>
.ba-grid{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:10px;margin:14px 0}
.ba-box{padding:14px;border-radius:12px;border:1px solid #e4e4e7}
.ba-box p{margin:6px 0 0;font-size:15px;color:#3f3f46}
.ba-before{background:#fef2f2;border-color:#fecaca}
.ba-after{background:#f0fdf4;border-color:#bbf7d0}
.ba-label{font-size:11px;font-weight:800;letter-spacing:.06em;color:#71717a}
.ba-arrow{font-size:22px;color:#d4d4d8}
@media(max-width:500px){
  .ba-grid{grid-template-columns:1fr;gap:6px}
  .ba-arrow{text-align:center}
}
</style>
