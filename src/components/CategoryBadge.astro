---
const { category } = Astro.props;
const label = category === 'lessons' ? '수업' : category === 'videos' ? '영상' : '업무일지';
---
<span class={`badge ${category}`}>{label}</span>

<style>
.badge{display:inline-flex;padding:4px 10px;border-radius:999px;border:1px solid var(--border);font-size:12px;color:#374151;background:#fff}
.badge.lessons{background:#eff6ff;border-color:#bfdbfe;color:#1d4ed8}
.badge.worklog{background:#f0fdf4;border-color:#bbf7d0;color:#166534}
.badge.videos{background:#fff7ed;border-color:#fed7aa;color:#9a3412}
</style>
