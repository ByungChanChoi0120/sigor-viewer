---
const { label, value, max = 100, color = '#3b82f6' } = Astro.props;
const pct = Math.min(100, Math.round((value / max) * 100));
---
<div class="prog-wrap">
  <div class="prog-header">
    <span class="prog-label">{label}</span>
    <span class="prog-value">{value}/{max} ({pct}%)</span>
  </div>
  <div class="prog-track">
    <div class="prog-fill" style={`width:${pct}%;background:${color}`}></div>
  </div>
</div>

<style>
.prog-wrap{margin:10px 0}
.prog-header{display:flex;justify-content:space-between;font-size:14px;margin-bottom:4px}
.prog-label{font-weight:700;color:#1a1a2e}
.prog-value{color:#71717a}
.prog-track{height:8px;background:#f4f4f5;border-radius:99px;overflow:hidden}
.prog-fill{height:100%;border-radius:99px;transition:width .3s ease}
</style>
