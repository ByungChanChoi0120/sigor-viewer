---
const { items = [] } = Astro.props;
---
<div class="timeline">
  {items.map((item: {time: string, text: string, highlight?: boolean}) => (
    <div class={`tl-item ${item.highlight ? 'tl-hl' : ''}`}>
      <span class="tl-dot"></span>
      <span class="tl-time">{item.time}</span>
      <span class="tl-text">{item.text}</span>
    </div>
  ))}
</div>

<style>
.timeline{margin:16px 0;padding-left:18px;border-left:2px solid #e4e4e7}
.tl-item{position:relative;padding:8px 0 8px 16px}
.tl-dot{position:absolute;left:-23px;top:14px;width:10px;height:10px;border-radius:50%;background:#d4d4d8;border:2px solid #fff}
.tl-hl .tl-dot{background:#3b82f6}
.tl-time{font-size:13px;font-weight:700;color:#3b82f6;margin-right:8px}
.tl-text{font-size:15px;color:#1a1a2e}
</style>
